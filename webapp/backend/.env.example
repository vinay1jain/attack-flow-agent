# Bring your own API key: set OPENAI_API_KEY (or use a LiteLLM-supported provider via the same env).
# Never commit .env or paste keys into the repo, issues, or frontend (no VITE_* secrets).
OPENAI_API_KEY=
LLM_MODEL=openai/gpt-4o
LLM_EXTRACTION_MODEL=openai/gpt-4o-mini
## ttp_chainer source root (must contain aaftre.py, stix_object_creator.py, stix_2_afb.py)
TTP_CHAINER_PATH=/absolute/path/to/ttp_chainer
FRONTEND_URL=http://localhost:5173
PORT=8000
