# Copy to .env for local use only; never commit .env or real API keys.
# === LLM Configuration ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# LiteLLM model string: openai/gpt-4o, anthropic/claude-3-sonnet, ollama/llama3, etc.
LLM_MODEL=openai/gpt-4o
LLM_EXTRACTION_MODEL=openai/gpt-4o-mini
# For TLP:RED reports, use a local model
LLM_LOCAL_MODEL=ollama/llama3

# === CTIX Configuration ===
CTIX_BASE_URL=https://your-ctix-instance.example.com
CTIX_ACCESS_ID=your-access-id
CTIX_SECRET_KEY=your-secret-key
CTIX_VERIFY_SSL=true

# === Agent Service ===
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_LOG_LEVEL=INFO

# === Rate Limiting ===
RATE_LIMIT_PER_TENANT=20
RATE_LIMIT_WINDOW_SECONDS=3600

# === Narrative Assembly ===
NARRATIVE_TOKEN_BUDGET=25000
NARRATIVE_MIN_SDOS=5

# === ttp_chainer Path ===
TTP_CHAINER_PATH=/app/ttp_chainer
